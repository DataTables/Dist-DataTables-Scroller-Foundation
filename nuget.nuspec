<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <version>3.0.0-beta.1</version>
        <id>datatables.net-scroller-zf</id>
        <description>This is Scroller for DataTables with styling for [Foundation](https://get.foundation/)</description>
        <repository type="git" url="https://github.com/DataTables/Scroller"/>
        <authors>SpryMedia Ltd</authors>
        <projectUrl>http://datatables.net</projectUrl>
        <license type="expression">MIT</license>
        <tags>Scroller  Virtual Scrolling  Foundation  Datatables table</tags>
        <dependencies>
            <dependency id="datatables.net-scroller" version="3.0.0-beta.1"/>
            <dependency id="datatables.net-zf" version="3.0.0-0"/>
        </dependencies>
        <contentFiles>
            <files include="**/*" buildAction="Content"/>
        </contentFiles>
        <readme>Readme.md</readme>
    </metadata>
    <files>
        <file src="Readme.md" target=""/>
        <file src="js/scroller.foundation.js" target="content\Scripts"/>
        <file src="js/scroller.foundation.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/scroller.foundation.min.js" target="content\Scripts"/>
        <file src="js/scroller.foundation.min.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/scroller.foundation.min.mjs" target="content\Scripts"/>
        <file src="js/scroller.foundation.min.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/scroller.foundation.mjs" target="content\Scripts"/>
        <file src="js/scroller.foundation.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="css/scroller.foundation.css" target="content\Content"/>
        <file src="css/scroller.foundation.css" target="contentFiles\any\any\wwwroot\css"/>
        <file src="css/scroller.foundation.min.css" target="content\Content"/>
        <file src="css/scroller.foundation.min.css" target="contentFiles\any\any\wwwroot\css"/>
    </files>
</package>
